APP_ENV=dev
APP_URL=http://localhost:8080
APP_DEBUG=1
# Атрибут lang у <html> (по умолчанию ru)
SITE_LANG=ru

DB_HOST=postgres
DB_PORT=5432
DB_NAME=monostain
DB_USER=monostain
DB_PASS=monostain

JWT_SECRET=replace_with_a_long_random_secret
JWT_TTL_SECONDS=3600
# Cookie stain_auth (должны совпадать при логине и выходе). В production при HTTPS:
# AUTH_COOKIE_SECURE=1
# SameSite: Strict | Lax | None (None требует Secure=1, используйте для кросс-сайтовых сценариев)
AUTH_COOKIE_SECURE=0
AUTH_COOKIE_SAMESITE=Lax
# Необязательно: домен cookie, например .example.com для поддоменов
# AUTH_COOKIE_DOMAIN=

# Общий лимит (legacy); для изображений и видео см. ниже
UPLOAD_MAX_BYTES=10485760
# Дополнительно выровнять с PHP (upload_max_filesize, post_max_size) и лимитом веб-сервера
# (на shared — часто панель хостинга или .user.ini; на VPS — nginx client_max_body_size).
# 5 МБ на изображение, 500 МБ на видео (байты)
UPLOAD_MAX_IMAGE_BYTES=5242880
UPLOAD_MAX_VIDEO_BYTES=524288000
ADMIN_EMAILS=admin@example.com
# Адрес From для писем с формы обратной связи (должен быть валидным email)
MAIL_FROM=noreply@example.com